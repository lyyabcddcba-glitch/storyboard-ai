page { background: #09090b; color: #e4e4e7; font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif; }
.page { padding: 0 24rpx 60rpx; min-height: 100vh; }

.header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 0 24rpx; }
.header-row { display: flex; align-items: center; gap: 14rpx; }
.logo { font-size: 44rpx; }
.header-text { display: flex; flex-direction: column; }
.title { font-size: 36rpx; font-weight: 900; color: #fff; line-height: 1.1; }
.accent { color: #f59e0b; }
.subtitle { font-size: 22rpx; color: #71717a; margin-top: 2rpx; }
.header-btns { display: flex; gap: 12rpx; }
.export-btn { padding: 14rpx 24rpx; background: linear-gradient(135deg, #f59e0b, #d97706); border-radius: 18rpx; }
.export-btn text { font-size: 24rpx; font-weight: 700; color: #000; }
.export-btn.disabled { opacity: 0.3; }
.share-btn { padding: 14rpx 24rpx; background: #27272a; border: 2rpx solid #3f3f46; border-radius: 18rpx; }
.share-btn text { font-size: 24rpx; font-weight: 600; color: #a1a1aa; }
.share-btn.disabled { opacity: 0.3; }

.input-panel { background: #18181b; border: 2rpx solid #27272a; border-radius: 24rpx; padding: 28rpx; margin-bottom: 28rpx; }
.field { margin-bottom: 22rpx; }
.field.half { flex: 1; margin-bottom: 0; }
.label { display: block; font-size: 22rpx; color: #71717a; margin-bottom: 10rpx; font-weight: 500; letter-spacing: 2rpx; }
.input { width: 100%; padding: 20rpx 24rpx; background: #09090b; border: 2rpx solid #27272a; border-radius: 16rpx; font-size: 28rpx; color: #e4e4e7; box-sizing: border-box; }
.row { display: flex; gap: 16rpx; margin-bottom: 22rpx; }
.picker { width: 100%; padding: 20rpx 24rpx; background: #09090b; border: 2rpx solid #27272a; border-radius: 16rpx; font-size: 28rpx; color: #e4e4e7; box-sizing: border-box; }
.generate-btn { width: 100%; padding: 26rpx; background: linear-gradient(135deg, #6366f1, #4f46e5); border-radius: 20rpx; font-size: 30rpx; font-weight: 700; color: #fff; border: none; }
.generate-btn.disabled { background: #27272a; color: #52525b; }
.generate-btn::after { border: none; }

.status { text-align: center; margin-top: 18rpx; }
.status-text { font-size: 24rpx; color: #71717a; }
.status-text.success { color: #22c55e; }
.status-text.error { color: #ef4444; }

.cards { display: flex; flex-direction: column; gap: 16rpx; }
.cards-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.cards-title { font-size: 26rpx; font-weight: 700; color: #e4e4e7; }
.cards-sub { font-size: 22rpx; color: #52525b; }

.card { background: #18181b; border: 2rpx solid #27272a; border-radius: 20rpx; overflow: hidden; }
.card.expanded { border-color: #6366f1; }
.card-head { padding: 20rpx 24rpx; }
.card-head-top { display: flex; justify-content: space-between; align-items: center; }
.card-head-left { display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap; }
.shot-id { font-size: 28rpx; font-weight: 900; color: #f59e0b; }
.shot-duration { font-size: 24rpx; color: #a1a1aa; }
.shot-size { font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 12rpx; font-weight: 600; border: 2rpx solid; }
.tag-closeup { color: #fca5a5; background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); }
.tag-mid { color: #93c5fd; background: rgba(59,130,246,0.1); border-color: rgba(59,130,246,0.3); }
.tag-wide { color: #86efac; background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.3); }
.tag-default { color: #a1a1aa; background: #27272a; border-color: #3f3f46; }
.card-head-right { display: flex; align-items: center; }
.shot-movement { font-size: 22rpx; color: #52525b; margin-left: 8rpx; }
.arrow { font-size: 28rpx; color: #52525b; }
.arrow.up { transform: rotate(180deg); }
.card-preview { margin-top: 10rpx; padding: 10rpx 0 0; border-top: 2rpx solid #27272a; }
.preview-text { font-size: 22rpx; color: #52525b; line-height: 1.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.card-body { padding: 0 24rpx 24rpx; }
.field-row { margin-bottom: 18rpx; }
.field-label { display: block; font-size: 20rpx; color: #6366f1; margin-bottom: 6rpx; font-weight: 600; }
.field-value { font-size: 26rpx; color: #d4d4d8; line-height: 1.7; white-space: pre-wrap; word-break: break-all; }
.field-value.dialogue { color: #fbbf24; font-style: italic; font-size: 28rpx; }
.card-actions { margin-top: 24rpx; padding-top: 20rpx; border-top: 2rpx solid #27272a; }
.copy-btn { display: inline-flex; padding: 14rpx 28rpx; background: #27272a; border-radius: 14rpx; }
.copy-btn text { font-size: 24rpx; color: #a1a1aa; }

.stream-preview { margin-top: 24rpx; }
.stream-indicator { display: flex; align-items: center; gap: 10rpx; margin-bottom: 14rpx; }
.stream-dot { font-size: 20rpx; color: #f59e0b; }
.stream-label { font-size: 24rpx; color: #71717a; }
.stream-box { background: #18181b; border: 2rpx solid #27272a; border-radius: 16rpx; padding: 20rpx; max-height: 300rpx; }
.stream-text { font-size: 22rpx; color: #52525b; white-space: pre-wrap; word-break: break-all; }

.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-icon { font-size: 80rpx; opacity: 0.3; margin-bottom: 24rpx; }
.empty-title { font-size: 28rpx; color: #52525b; }
.empty-desc { font-size: 24rpx; color: #3f3f46; margin-top: 8rpx; }
