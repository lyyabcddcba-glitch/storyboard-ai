# ==========================================
# AI 分镜脚本生成系统 - 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ==========================================

# DeepSeek API Key（必填）
# 获取地址: https://platform.deepseek.com
# 费用: 100万字 ≈ 2元
DEEPSEEK_API_KEY=sk-your-key-here

# 可选：其他模型提供商
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# 可选：服务端口（默认3000）
PORT=3000
